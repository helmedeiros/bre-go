# Large generated artifacts are reproducible by running the harness.
# Commit the evidence (timings, reports, logs), not the bulk inputs.
results/**/rules.csv
results/**/snapshot.json
results/**/inputs.jsonl
results/**/results-source.jsonl
results/**/results-snapshot.jsonl
results/**/results-snapshot-*.jsonl
results/docker-build.*.log

# Anchored to the suite root: stray `go build` outputs produced by
# running `go build ./cmd/...` here. These names also exist as
# cmd/ subdirectories; un-anchored patterns would ignore the
# subdirectories themselves and silently drop their source files.
/scigen
/sci-build
/sci-load
/sci-compare
/sci-stats
/sci-adv
/sci-refusals
/build
/load
/compare
/stats
/adversarial
/refusals
